# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit actual keys.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service-role key is used for backend/admin operations only (e.g. creating
# demo shadow orgs). Never expose it client-side or prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
